        ]
      ]
    },
    "Telegram: Envoyer le rapport": { "main": [[{ "node": "Log Rapport dans Sheets", "type": "main", "index": 0 }]] },
    "Gmail: Envoyer le rapport": { "main": [[{ "node": "Log Rapport dans Sheets", "type": "main", "index": 0 }]] }
  },
  "settings": { "executionOrder": "v1", "saveManualExecutions": true },
  "meta": { "instanceId": "rapport-quotidien-anis-v1" }
}

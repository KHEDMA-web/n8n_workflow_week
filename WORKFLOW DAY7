        "description": "Identifie les clients dont l'onboarding n'est pas terminé (étape de la checklist manquante : email de bienvenue, kickoff call, accès outils ou premier livrable). Passe-lui le tableau JSON lu via l'outil Lire Onboarding.",
        "language": "javaScript",
        "jsCode": "const raw = $fromAI('onboarding', 'Tableau JSON des lignes Onboarding à analyser, sous forme de chaîne de caractères');\nlet rows;\ntry {\n  rows = JSON.parse(raw);\n} catch (e) {\n  return { error: 'JSON invalide reçu en entrée: ' + e.message };\n}\nif (!Array.isArray(rows)) rows = [rows];\n\nconst etapes = ['Email de bienvenue', 'Kickoff call', 'Accès outils', 'Premier livrable'];\nconst enAttente = [];\n\nfor (const r of rows) {\n  const manquantes = etapes.filter((etape) => {\n    const val = (r[etape] || '').toString().toLowerCase();\n    return val !== 'oui' && val !== 'true' && val !== '1';\n  });\n  if (manquantes.length > 0) enAttente.push({ ...r, etapesManquantes: manquantes });\n}\n\nreturn { total: enAttente.length, clients: enAttente };"

    {
      "parameters": {
        "name": "lister_prospects_a_relancer",
        "description": "Identifie les prospects à relancer aujourd'hui, en appliquant la même logique de délai que le workflow de relance automatique du Jour 3 : 3 jours après le 1er contact, 5 jours après la 2ème relance, 7 jours après la 3ème, maximum 3 relances. Passe-lui le tableau JSON des prospects (lu via l'outil Lire Prospects) et la date du jour.",
        "language": "javaScript",
        "jsCode": "const raw = $fromAI('prospects', 'Tableau JSON des prospects à analyser, sous forme de chaîne de caractères');\nconst todayStr = $fromAI('dateDuJour', 'Date du jour au format AAAA-MM-JJ');\nlet rows;\ntry {\n  rows = JSON.parse(raw);\n} catch (e) {\n  return { error: 'JSON invalide reçu en entrée: ' + e.message };\n}\nif (!Array.isArray(rows)) rows = [rows];\n\nconst today = new Date(todayStr);\nconst delais = { 0: 3, 1: 5, 2: 7 };\nconst aRelancer = [];\n\nfor (const r of rows) {\n  const statut = r.Statut || r.statut;\n  if (statut !== 'en cours') continue;\n  const nbRelances = parseInt(r['Relances envoyées'] || r.relances || '0', 10);\n  if (nbRelances >= 3) continue;\n  const dernierContact = r['Dernier contact'] || r.dernierContact;\n  if (!dernierContact) continue;\n  const last = new Date(dernierContact);\n  const joursEcoules = Math.floor((today - last) / (1000 * 60 * 60 * 24));\n  const seuil = delais[nbRelances] ?? 7;\n  if (joursEcoules >= seuil) aRelancer.push({ ...r, joursEcoules, nbRelances });\n}\n\nreturn { total: aRelancer.length, prospects: aRelancer };"
      },
      "id": "tool-prospects-relance",
      "name": "Outil: Lister Prospects à Relancer",

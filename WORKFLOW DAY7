    {
      "parameters": {
        "name": "lister_projets_en_retard",
        "description": "Identifie les projets en cours dont l'échéance est dépassée, en appliquant la même logique que le workflow de suivi hebdomadaire du Jour 6. Passe-lui le tableau JSON des projets (lu via l'outil Lire Projets) et la date du jour.",
        "language": "javaScript",
        "jsCode": "const raw = $fromAI('projets', 'Tableau JSON des projets à analyser, sous forme de chaîne de caractères');\nconst todayStr = $fromAI('dateDuJour', 'Date du jour au format AAAA-MM-JJ');\nlet rows;\ntry {\n  rows = JSON.parse(raw);\n} catch (e) {\n  return { error: 'JSON invalide reçu en entrée: ' + e.message };\n}\nif (!Array.isArray(rows)) rows = [rows];\n\nconst today = new Date(todayStr);\nconst enRetard = [];\n\nfor (const r of rows) {\n  const statut = r.Statut || r.statut;\n  if (statut !== 'en cours') continue;\n  const echeanceStr = r['Échéance'] || r.echeance;\n  if (!echeanceStr) continue;\n  const echeance = new Date(echeanceStr);\n  if (echeance < today) {\n    const joursRetard = Math.ceil((today - echeance) / (1000 * 60 * 60 * 24));\n    enRetard.push({ ...r, joursRetard });\n  }\n}\n\nreturn { total: enRetard.length, projets: enRetard };"
      },
      "id": "tool-projets-retard",

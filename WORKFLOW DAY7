        "language": "javaScript",
        "jsCode": "const prospectsRaw = $fromAI('prospects', 'Tableau JSON des prospects, sous forme de chaîne de caractères, ou chaîne vide si non disponible');\nconst projetsRaw = $fromAI('projets', 'Tableau JSON des projets, sous forme de chaîne de caractères, ou chaîne vide si non disponible');\nconst inboxRaw = $fromAI('inbox', \"Tableau JSON des emails de l'Inbox Log, sous forme de chaîne de caractères, ou chaîne vide si non disponible\");\n\nfunction safeParse(raw) {\n  if (!raw) return [];\n  try {\n    const parsed = JSON.parse(raw);\n    return Array.isArray(parsed) ? parsed : [parsed];\n  } catch (e) {\n    return [];\n  }\n}\n\nconst prospects = safeParse(prospectsRaw);\nconst projets = safeParse(projetsRaw);\nconst inbox = safeParse(inboxRaw);\n\nconst dealsGagnes = prospects.filter((p) => (p.Statut || p.statut) === 'gagné').length;\nconst projetsActifs = projets.filter((p) => (p.Statut || p.statut) === 'en cours').length;\nconst emailsUrgents = inbox.filter((e) => (e.Categorie || e.categorie) === 'urgent').length;\n\nreturn { dealsGagnes, projetsActifs, emailsUrgents };"
